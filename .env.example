# AI providers — the /api/tutor route uses whichever key is present.
# If neither is set, the AI Tutor returns rich mock responses (safe for prototype/demo).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase (not required for the prototype — data is mocked in src/lib/mockData.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API (optional — Hit Lab uses mock metadata when absent)
YOUTUBE_API_KEY=
