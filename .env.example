# AI providers — used server-side by the API routes (/api/tutor, /api/hooks, …).
# Whichever key is present is used; if neither is set, routes return rich mock
# responses so every feature works offline. Copy this file to .env.local.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase (not required for the prototype — data is mocked in src/lib/mockData.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API (optional — Hit Lab uses mock metadata when absent)
YOUTUBE_API_KEY=
